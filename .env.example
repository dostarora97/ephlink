# ephlink — environment template.
# Copy to `.env` (gitignored) and fill in your own values. `.env` is loaded automatically.
#
# Tailscale OAuth client secret with the `auth_keys` write scope, tagged tag:ephlink-agent.
# Create one in the Tailscale admin console (Settings → OAuth clients). Operator-side only.
TS_OAUTH_CLIENT_SECRET=tskey-client-xxxxxxxxxxxxxxxxxxxx

# Optional: a pre-minted ephemeral node key (else use the `mint` tool). Short-lived.
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxx
